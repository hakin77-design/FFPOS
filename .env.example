# API Keys
FOOTBALL_API_KEY=your_football_data_api_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
SOFASCORE_API_KEY=your_sofascore_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/matches.db
DB_ECHO=False

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600

# Application
APP_NAME=FFPAS
APP_VERSION=2.0.0
DEBUG=False
PORT=5000
HOST=0.0.0.0

# Model
MODEL_PATH=ai_model.pt
MODEL_VERSION=latest
BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
API_RATE_LIMIT=100/minute

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
